generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(cuid())
  username            String              @unique
  password            String
  name                String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  role                Role                @default(USER)
  aestheticPreference AestheticPreference @default(CLASSIC)
  baseCurrency        String              @default("GBP")
  email               String?             @unique
  onboardingComplete  Boolean             @default(false)
  ownedTrips          Trip[]              @relation("TripOwner")
  sharedTrips         Trip[]              @relation("TripCollaborators")
}

model Trip {
  id                   String     @id @default(cuid())
  destination          String
  destinationPlaceId   String?
  startDate            DateTime?
  endDate              DateTime?
  duration             Int
  budgetGBP            Int
  bookingMode          String     @default("planning")
  defaultOriginCoords  Json?
  intake               Json?
  itinerary            Json?
  lockedAccommodations Json?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  ownerId              String
  documents            Document[]
  owner                User       @relation("TripOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  collaborators        User[]     @relation("TripCollaborators")

  @@index([ownerId])
}

model Document {
  id         String   @id @default(cuid())
  tripId     String
  poiId      String?
  fileName   String
  fileUrl    String
  mimeType   String?
  sizeBytes  Int?
  uploadedAt DateTime @default(now())
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

enum AestheticPreference {
  CLASSIC
  EDITORIAL
  NOTEBOOK
  TERMINAL
  CONCIERGE
}

enum Role {
  ADMIN
  USER
}
