generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(cuid())
  username            String              @unique
  password            String
  name                String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  role                Role                @default(USER)
  aestheticPreference AestheticPreference @default(CLASSIC)
  baseCurrency        String              @default("GBP")
  email               String?             @unique
  onboardingComplete  Boolean             @default(false)
  ownedTrips          Trip[]              @relation("TripOwner")
  sharedTrips         Trip[]              @relation("TripCollaborators")
}

model Trip {
  id                   String     @id @default(cuid())
  destination          String
  destinationPlaceId   String?
  startDate            DateTime?
  endDate              DateTime?
  duration             Int
  budgetGBP            Int
  bookingMode          String     @default("planning")
  defaultOriginCoords  Json?
  intake               Json?
  itinerary            Json?
  lockedAccommodations Json?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  ownerId              String
  documents            Document[]
  bookings             Booking[]
  owner                User       @relation("TripOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  collaborators        User[]     @relation("TripCollaborators")

  @@index([ownerId])
}

model Document {
  id         String   @id @default(cuid())
  tripId     String
  poiId      String?
  bookingId  String?
  fileName   String
  fileUrl    String
  mimeType   String?
  sizeBytes  Int?
  uploadedAt DateTime @default(now())
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  booking    Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([bookingId])
}

enum AestheticPreference {
  CLASSIC
  EDITORIAL
  NOTEBOOK
  TERMINAL
  CONCIERGE
}

enum Role {
  ADMIN
  USER
}

enum BookingType {
  FLIGHT
  TRAIN
  ACCOMMODATION
  CAR_HIRE
  TRANSFER
  OTHER
}

model Booking {
  id              String      @id @default(cuid())
  tripId          String
  trip            Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)

  type            BookingType

  // What
  title           String      // "British Airways BA456" or "The Hoxton Hotel"
  confirmationRef String?     // PNR, booking reference
  notes           String?

  // When
  startDate       DateTime
  endDate         DateTime?   // null for single-point events like a flight departure

  // Where (Routing Anchors)
  placeId         String?     // Google Maps Place ID (crucial for timeline recalc)
  address         String?
  lat             Float?      // Explicit floats instead of Json for type safety
  lng             Float?

  // Destination Routing Anchors (Crucial for Flights/Trains crossing cities)
  destinationPlaceId String?
  destinationAddress String?
  destinationLat     Float?
  destinationLng     Float?

  // Specifics
  originName      String?     // "LHR Terminal 5"
  destinationName String?     // "JFK Terminal 8"
  flightNumber    String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Attached Documents (Tickets, Confirmations)
  documents       Document[]

  @@index([tripId])
  @@map("bookings")
}
