generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── USERS & COLLABORATION ────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  ownedTrips    Trip[]    @relation("TripOwner")
  sharedTrips   Trip[]    @relation("TripCollaborators")
}

// ── THE TRIP (The Master Container) ──────────────────────────────────────────
model Trip {
  id               String    @id @default(cuid())
  ownerId          String
  owner            User      @relation("TripOwner", fields: [ownerId], references: [id])
  collaborators    User[]    @relation("TripCollaborators")

  title            String    
  destination      String    
  startDate        DateTime? 
  endDate          DateTime?
  isBooked         Boolean   @default(false) // The Planning vs Booked toggle
  
  // Stores "Need to Know" and Intake info (Essentials, weather, etc.)
  overviewData     Json?     

  days             Day[]     
  pois             POI[]     // All POIs, including those in the "Bucket List"

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ── THE DAY (The Schedule Bucket) ────────────────────────────────────────────
model Day {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  
  date      DateTime 
  location  String?  // Supports Multi-city (e.g. Vienna -> Bratislava)
  theme     String?  
  dayNotes  String?  

  pois      POI[]    
}

// ── THE POI (The Activity / Booking) ─────────────────────────────────────────
model POI {
  id                  String    @id @default(cuid())
  tripId              String
  trip                Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  
  // THE BUCKET LIST: If dayId is null, it sits in 'Unscheduled'
  dayId               String?   
  day                 Day?      @relation(fields: [dayId], references: [id])

  // THE DNA
  name                String
  category            String    @default("ACTIVITY") // FLIGHT, TRAIN, HOTEL, ACTIVITY
  googlePlaceId       String?   
  latitude            Float?
  longitude           Float?
  
  // THE LOGISTICS
  startTime           DateTime? // Map to 'arrivalTime' in your recalc
  endTime             DateTime? // Map to 'departureTime' in your recalc
  isFixed             Boolean   @default(false)
  dwellTime           Int?      // Minutes (Duration)
  transitTimeOutbound Int?      // Buffer to next stop

  // THE FILING CABINET & NOTES
  reservationRef      String?   
  documentUrl         String?   
  userNotes           String?   
  schedulingReason    String?   // "Why" it's unscheduled (too far, etc.)

  // THE SAFETY NET
  deletedAt           DateTime? 

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}