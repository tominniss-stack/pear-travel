generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── USERS & COLLABORATION ────────────────────────────────────────────────────
model User {
  id          String   @id @default(cuid())
  name        String?
  email       String?  @unique
  ownedTrips  Trip[]   @relation("TripOwner")
  sharedTrips Trip[]   @relation("TripCollaborators")
}

// ── THE TRIP (The Master Container) ──────────────────────────────────────────
model Trip {
  id           String    @id @default(cuid())
  ownerId      String
  owner        User      @relation("TripOwner", fields: [ownerId], references: [id])
  collaborators User[]   @relation("TripCollaborators")

  title        String
  destination  String
  startDate    DateTime?
  endDate      DateTime?
  isBooked     Boolean   @default(false)

  // ── VITAL FOR UI & AI LOGIC ──
  budgetGBP    Float     @default(0)
  duration     Int       @default(1)
  
  // Stores Intake info (Interests, Pace, etc.)
  intakeData   Json?     
  
  // Stores "Need to Know" (Essentials, Local currency info, Weather avg)
  overviewData Json?     

  days         Day[]
  pois         POI[]     

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ── THE DAY (The Schedule Bucket) ────────────────────────────────────────────
model Day {
  id         String    @id @default(cuid())
  tripId     String
  trip       Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  
  date       DateTime? // Optional for "Planning" phase
  orderIndex Int       // Sequence (0, 1, 2...)
  
  location   String?   
  theme      String?   
  dayNotes   String?   

  pois       POI[]     
}

// ── THE POI (The Activity / Booking) ─────────────────────────────────────────
model POI {
  id                  String    @id @default(cuid())
  tripId              String
  trip                Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  
  dayId               String?   
  day                 Day?      @relation(fields: [dayId], references: [id])

  // THE DNA
  name                String
  category            String    @default("ACTIVITY") 
  description         String?
  googlePlaceId       String?   
  latitude            Float?
  longitude           Float?
  
  // THE LOGISTICS
  startTime           String?   // Store as "HH:mm" for waterfall logic
  endTime             String?   
  costGBP             Float     @default(0)
  isFixed             Boolean   @default(false)
  dwellTime           Int?      // Minutes
  orderIndex          Int       // Position within the day
  
  // TRANSIT INFO
  transitMethod       String?   
  transitNote         String?   

  // DOCUMENTATION
  reservationRef      String?   
  documentUrl         String?   
  userNotes           String?   

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}